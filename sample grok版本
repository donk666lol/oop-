from .node import Node

class DoublyLinkedList:
    def __init__(self):
        self.head = None
        self.tail = None
        self._size = 0

    def append(self, data):
        new_node = Node(data)
        if not self.head:
            self.head = new_node
            self.tail = new_node
        else:
            self.tail.next = new_node
            new_node.prev = self.tail
            self.tail = new_node
        self._size += 1

    def find(self, key, key_attr='member_id'):
        current = self.head
        while current:
            if getattr(current.data, key_attr, None) == key:
                return current.data
            current = current.next
        return None

    def remove(self, key, key_attr='member_id'):
        current = self.head
        while current:
            if getattr(current.data, key_attr, None) == key:
                if current.prev:
                    current.prev.next = current.next
                else:
                    self.head = current.next
                if current.next:
                    current.next.prev = current.prev
                else:
                    self.tail = current.prev
                self._size -= 1
                return True
            current = current.next
        return False

    def to_list(self):
        result = []
        current = self.head
        while current:
            result.append(current.data)
            current = current.next
        return result

    @property
    def size(self):
        return self._size
