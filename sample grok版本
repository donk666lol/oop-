import pickle
import os
from data_structures.doubly_linked_list import DoublyLinkedList
from data_structures.stack import Stack
from data_structures.queue import Queue
from data_structures.binary_search_tree import BinarySearchTree
from data_structures.hash_table import HashTable
from models.book import Book
from models.member import StudentMember, FacultyMember

class LibraryException(Exception):
    pass

class BookNotFoundError(LibraryException):
    pass

class LibrarySystem:
    def __init__(self):
        self.filename = 'library_data.pkl'
        self.books_hash = HashTable()
        self.books_bst = BinarySearchTree()
        self.members_dll = DoublyLinkedList()
        self.reservation_queue = Queue()
        self.undo_stack = Stack()

        if os.path.exists(self.filename):
            self.load_data()
        else:
            self.initialize_data()
            self.save_data()

    def initialize_data(self):
        books = [
            Book("978-0-262-13472-9", "算法导论", "Thomas H. Cormen", True),
            Book("978-0-13-235613-8", "程序员修炼之道", "Andrew Hunt", True),
            Book("ISBN001", "Python数据分析", "Wes McKinney", True),
            Book("ISBN002", "代码整洁之道", "Robert C. Martin", True),
            Book("ISBN003", "设计模式", "Erich Gamma", True),
            Book("ISBN004", "人月神话", "Frederick Brooks", True),
            Book("ISBN005", "代码大全", "Steve McConnell", True),
            Book("ISBN006", "重构", "Martin Fowler", True),
            Book("ISBN007", "领域驱动设计", "Eric Evans", True),
            Book("ISBN008", "计算机程序设计艺术", "Donald Knuth", True),
        ]
        for book in books:
            self.books_hash.insert(book.isbn, book)
            self.books_bst.insert(book)

        members = [
            StudentMember("S001", "张三"),
            FacultyMember("F001", "李四"),
            StudentMember("S002", "王五"),
            FacultyMember("F002", "赵六"),
            StudentMember("S003", "孙七"),
        ]
        for m in members:
            self.members_dll.append(m)

        try:
            self.borrow_book("S001", "ISBN001")
        except:
            pass
        print("✅ 初始数据集已创建并持久化")

    def save_data(self):
        data = {
            'books_hash': self.books_hash,
            'books_bst': self.books_bst,
            'members_dll': self.members_dll,
            'reservation_queue': self.reservation_queue,
            'undo_stack': self.undo_stack,
        }
        with open(self.filename, 'wb') as f:
            pickle.dump(data, f)

    def load_data(self):
        with open(self.filename, 'rb') as f:
            data = pickle.load(f)
            self.books_hash = data['books_hash']
            self.books_bst = data['books_bst']
            self.members_dll = data['members_dll']
            self.reservation_queue = data['reservation_queue']
            self.undo_stack = data['undo_stack']
        print("✅ 数据已从文件加载")

    def add_book(self, isbn, title, author):
        if self.books_hash.get(isbn):
            raise LibraryException("书籍已存在")
        book = Book(isbn, title, author)
        self.books_hash.insert(isbn, book)
        self.books_bst.insert(book)
        self.save_data()
        return book

    def add_member(self, mtype, member_id, name):
        if self.members_dll.find(member_id):
            raise LibraryException("成员已存在")
        member = StudentMember(member_id, name) if mtype == "student" else FacultyMember(member_id, name)
        self.members_dll.append(member)
        self.save_data()
        return member

    def borrow_book(self, member_id, isbn):
        member = self.members_dll.find(member_id)
        if not member:
            raise LibraryException("成员不存在")
        book = self.books_hash.get(isbn)
        if not book:
            raise BookNotFoundError(isbn)
        if not book.available:
            self.reservation_queue.enqueue((member_id, isbn))
            raise LibraryException("书籍已被借出，已加入预约队列")
        if not member.can_borrow():
            raise LibraryException(f"借阅上限已达（{member.get_max_borrow()}本）")
        book.available = False
        book.borrower = member_id
        member.borrowed_books.append(isbn)
        self.undo_stack.push(('borrow', member_id, isbn))
        self.save_data()
        return True

    def return_book(self, member_id, isbn):
        member = self.members_dll.find(member_id)
        book = self.books_hash.get(isbn)
        if not book or book.borrower != member_id:
            raise LibraryException("归还信息错误")
        book.available = True
        book.borrower = None
        if isbn in member.borrowed_books:
            member.borrowed_books.remove(isbn)
        self.undo_stack.push(('return', member_id, isbn))
        self.save_data()
        return True

    def undo_last_action(self):
        action = self.undo_stack.pop()
        if not action:
            return "没有可撤销的操作"
        typ, mid, isbn = action
        if typ == 'borrow':
            self.return_book(mid, isbn)
        else:
            self.borrow_book(mid, isbn)
        return f"已撤销 {typ} 操作"

    def search_book(self, query):
        book = self.books_hash.get(query)
        if book:
            return book
        return self.books_bst.search(query)

    def list_all_books(self):
        return self.books_bst.inorder_traversal()

    def list_all_members(self):
        return self.members_dll.to_list()

    def update_book(self, isbn, new_title=None, new_author=None):
        book = self.books_hash.get(isbn)
        if not book:
            raise BookNotFoundError(isbn)
        if new_title:
            book.title = new_title
        if new_author:
            book.author = new_author
        self.save_data()

    def delete_book(self, isbn):
        book = self.books_hash.get(isbn)
        if not book:
            raise BookNotFoundError(isbn)
        if not book.available:
            raise LibraryException("已借出书籍无法删除")
        self.books_hash.remove(isbn)
        self.save_data()

    def view_reservation_queue(self):
        q = []
        temp = self.reservation_queue
        while not temp.is_empty():
            q.append(temp.dequeue())
        return q
