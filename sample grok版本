from abc import ABC, abstractmethod

class LibraryItem(ABC):
    @abstractmethod
    def get_details(self) -> str:
        pass

class Book(LibraryItem):
    def __init__(self, isbn: str, title: str, author: str, available: bool = True):
        self.isbn = isbn
        self.title = title
        self.author = author
        self.available = available
        self.borrower = None

    def get_details(self) -> str:
        status = "可借" if self.available else f"已借出（借阅人：{self.borrower}）"
        return f"ISBN: {self.isbn} | 《{self.title}》 | 作者: {self.author} | 状态: {status}"

    def __lt__(self, other):
        return self.title < other.title if isinstance(other, Book) else False
