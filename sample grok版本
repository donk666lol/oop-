from .node import Node

class Stack:
    def __init__(self):
        self.top = None
        self._size = 0

    def push(self, data):
        new_node = Node(data)
        new_node.next = self.top
        self.top = new_node
        self._size += 1

    def pop(self):
        if not self.top:
            return None
        data = self.top.data
        self.top = self.top.next
        self._size -= 1
        return data

    def is_empty(self):
        return self.top is None

    @property
    def size(self):
        return self._size
